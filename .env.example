# Copy to .env and fill in your key. .env is gitignored.
GEMINI_API_KEY=

# Optional: Gmail app password to auto-fetch Greenhouse security codes.
# Generate one at myaccount.google.com -> Security -> App passwords (requires 2FA on the account).
# When set, the engine polls your inbox via IMAP after submit and pulls the code automatically.
GMAIL_APP_PASSWORD=

# Optional override (default: gemini-2.5-flash)
# APPLY_ENGINE_MODEL=gemini-2.5-flash
